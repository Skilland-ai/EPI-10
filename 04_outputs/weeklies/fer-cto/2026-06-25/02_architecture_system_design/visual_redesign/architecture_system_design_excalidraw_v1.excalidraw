      "text": "Architecture rules, gates and detail that should stay visible but not crowd the main picture",
      "fontSize": 22,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Architecture rules, gates and detail that should stay visible but not crowd the main picture",
