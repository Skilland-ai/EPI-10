      "boundElements": [],
      "updated": 1782265000000,
      "link": null,
      "locked": false,
      "text": "Flow 2 - Portal onboarding -> Odoo state\nHealthie forms/consents/docs emit webhook or validated polling -> MVP maps event -> Odoo state, dates, flags and next tasks. Missing data creates recovery task.",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flow 2 - Portal onboarding -> Odoo state\nHealthie forms/consents/docs emit webhook or validated polling -> MVP maps event -> Odoo state, dates, flags and next tasks. Missing data creates recovery task.",
      "autoResize": false,
      "lineHeight": 1.18
    },
