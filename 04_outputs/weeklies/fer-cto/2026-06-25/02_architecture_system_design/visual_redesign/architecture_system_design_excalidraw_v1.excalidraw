      "updated": 1782265000000,
      "link": null,
      "locked": false,
      "text": "TellmeGen B2B\nExternal/manual in Fase 1.\nNo automatic users, tests, barcodes, result polling, PDF downloads or structured genetic ingestion.\nEquipo updates Odoo milestones manually.",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TellmeGen B2B\nExternal/manual in Fase 1.\nNo automatic users, tests, barcodes, result polling, PDF downloads or structured genetic ingestion.\nEquipo updates Odoo milestones manually.",
      "autoResize": false,
      "lineHeight": 1.2
    },
