      "updated": 1782265000000,
      "link": null,
      "locked": false,
      "text": "Flow 1 - Lead/payment -> operational case\nCliente -> web/pago -> MVP validates schema/auth/idempotency -> PostgreSQL ledger -> Odoo contact/case/state/task -> Healthie invite only if validated.",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flow 1 - Lead/payment -> operational case\nCliente -> web/pago -> MVP validates schema/auth/idempotency -> PostgreSQL ledger -> Odoo contact/case/state/task -> Healthie invite only if validated.",
      "autoResize": false,
      "lineHeight": 1.18
