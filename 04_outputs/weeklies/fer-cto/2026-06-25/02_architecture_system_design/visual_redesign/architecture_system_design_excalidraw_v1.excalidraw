      "updated": 1782265000000,
      "link": null,
      "locked": false,
      "text": "Human report process\nEquipo prepares authorized inputs, checks pseudonymization, reviews draft and approves or rejects final report.",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Human report process\nEquipo prepares authorized inputs, checks pseudonymization, reviews draft and approves or rejects final report.",
