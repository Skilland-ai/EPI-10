      "updated": 1782265000000,
      "link": null,
      "locked": false,
      "text": "State lifecycle draft\nlead_received -> payment_pending -> payment_confirmed -> portal invite -> onboarding/forms/consents/docs -> tellmegen_manual_pending -> tellmegen_result_available -> ready_for_report -> human review -> report_delivered -> follow_up_active -> closed. incident branches to manual recovery.",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "State lifecycle draft\nlead_received -> payment_pending -> payment_confirmed -> portal invite -> onboarding/forms/consents/docs -> tellmegen_manual_pending -> tellmegen_result_available -> ready_for_report -> human review -> report_delivered -> follow_up_active -> closed. incident branches to manual recovery.",
      "autoResize": false,
      "lineHeight": 1.16
