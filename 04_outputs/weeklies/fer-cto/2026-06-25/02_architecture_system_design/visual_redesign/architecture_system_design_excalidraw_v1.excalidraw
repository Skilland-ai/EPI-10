    {"id":"text_fer","type":"text","x":88,"y":572,"width":260,"height":110,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_fer"],"frameId":null,"roundness":null,"seed":2103,"version":1,"versionNonce":2103,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"Fer review gates\n- ADRs and risks\n- Data boundary\n- State model\n- Healthie/Odoo gates\n- First vertical slice\n- Support boundaries","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Fer review gates\n- ADRs and risks\n- Data boundary\n- State model\n- Healthie/Odoo gates\n- First vertical slice\n- Support boundaries","autoResize":false,"lineHeight":1.2},

    {"id":"text_mvp","type":"text","x":492,"y":172,"width":535,"height":145,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_mvp"],"frameId":null,"roundness":null,"seed":2201,"version":1,"versionNonce":2201,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"EPI10 MVP orchestration service\nOwned by EPI10. Lightweight Fase 1 deployment in AWS Espana.\nBackend default: TypeScript / NestJS.\nOwns: event intake, auth/signature validation, idempotency, state routing, provider clients, retries, technical traceability and report handoff.\nMust not own: portal UI, Odoo UI, raw genetic data, clinical document repository.","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"EPI10 MVP orchestration service\nOwned by EPI10. Lightweight Fase 1 deployment in AWS Espana.\nBackend default: TypeScript / NestJS.\nOwns: event intake, auth/signature validation, idempotency, state routing, provider clients, retries, technical traceability and report handoff.\nMust not own: portal UI, Odoo UI, raw genetic data, clinical document repository.","autoResize":false,"lineHeight":1.2},
    {"id":"text_modules","type":"text","x":488,"y":382,"width":232,"height":145,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_modules"],"frameId":null,"roundness":null,"seed":2202,"version":1,"versionNonce":2202,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"Internal modules\n- auth/signature\n- idempotency\n- state engine\n- task engine\n- Odoo client\n- Healthie client if valid\n- report upload handoff","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Internal modules\n- auth/signature\n- idempotency\n- state engine\n- task engine\n- Odoo client\n- Healthie client if valid\n- report upload handoff","autoResize":false,"lineHeight":1.2},
    {"id":"text_postgres","type":"text","x":798,"y":382,"width":232,"height":145,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_postgres"],"frameId":null,"roundness":null,"seed":2203,"version":1,"versionNonce":2203,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"PostgreSQL tecnico\nAllowed only:\n- external IDs\n- event metadata\n- state snapshots\n- idempotency keys\n- retries/errors\n- sanitized audit markers\nNo raw genetic data.","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"PostgreSQL tecnico\nAllowed only:\n- external IDs\n- event metadata\n- state snapshots\n- idempotency keys\n- retries/errors\n- sanitized audit markers\nNo raw genetic data.","autoResize":false,"lineHeight":1.2},
    {"id":"text_recovery","type":"text","x":580,"y":628,"width":360,"height":125,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_recovery"],"frameId":null,"roundness":null,"seed":2204,"version":1,"versionNonce":2204,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"Error / retry / recovery path\n- bounded retries\n- operation-level idempotency where possible\n- retry exhaustion -> dead-letter\n- sanitized failure class\n- Odoo manual recovery task\n- owner alert for high severity\n- replay by event id/case id only","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Error / retry / recovery path\n- bounded retries\n- operation-level idempotency where possible\n- retry exhaustion -> dead-letter\n- sanitized failure class\n- Odoo manual recovery task\n- owner alert for high severity\n- replay by event id/case id only","autoResize":false,"lineHeight":1.2},

    {"id":"text_odoo","type":"text","x":1178,"y":172,"width":204,"height":125,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_odoo"],"frameId":null,"roundness":null,"seed":2301,"version":1,"versionNonce":2301,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"Odoo backoffice\nOperational source of truth:\ncontacts, cases, states, tasks, owners, dashboard, report markers and manual TellmeGen milestones.\nNo raw genetic data.","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Odoo backoffice\nOperational source of truth:\ncontacts, cases, states, tasks, owners, dashboard, report markers and manual TellmeGen milestones.\nNo raw genetic data.","autoResize":false,"lineHeight":1.2},
    {"id":"text_healthie","type":"text","x":1458,"y":172,"width":204,"height":125,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_healthie"],"frameId":null,"roundness":null,"seed":2302,"version":1,"versionNonce":2302,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"Healthie portal hypothesis\nOnboarding, forms, consents, questionnaires, documents, communication and report delivery if API/DPA/cost validate.\nUnknown/gated.","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Healthie portal hypothesis\nOnboarding, forms, consents, questionnaires, documents, communication and report delivery if API/DPA/cost validate.\nUnknown/gated.","autoResize":false,"lineHeight":1.2},
    {"id":"text_tellmegen","type":"text","x":1178,"y":387,"width":204,"height":125,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_tellmegen"],"frameId":null,"roundness":null,"seed":2303,"version":1,"versionNonce":2303,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"TellmeGen B2B\nExternal/manual in Fase 1.\nNo automatic users, tests, barcodes, status polling, PDF downloads or structured genetic ingestion.\nAitor/equipo updates Odoo manually.","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"TellmeGen B2B\nExternal/manual in Fase 1.\nNo automatic users, tests, barcodes, status polling, PDF downloads or structured genetic ingestion.\nAitor/equipo updates Odoo manually.","autoResize":false,"lineHeight":1.2},
    {"id":"text_copilot","type":"text","x":1458,"y":387,"width":204,"height":148,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_copilot"],"frameId":null,"roundness":null,"seed":2304,"version":1,"versionNonce":2304,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"EPI10 Informe Final Copilot\nDraft support only.\nPseudonymized package, authorized tools, human review checklist, final approval by EPI10.\nNo autonomous diagnosis or final report authority.","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"EPI10 Informe Final Copilot\nDraft support only.\nPseudonymized package, authorized tools, human review checklist, final approval by EPI10.\nNo autonomous diagnosis or final report authority.","autoResize":false,"lineHeight":1.2},
    {"id":"text_contracts","type":"text","x":1178,"y":622,"width":480,"height":135,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_contracts"],"frameId":null,"roundness":null,"seed":2305,"version":1,"versionNonce":2305,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"Integration contracts to define\nweb/pago: events, fields, auth/signature, idempotency, sandbox, retries.\nHealthie: API/webhooks, report delivery, DPA/GDPR/residency, cost.\nOdoo: version, auth, object model, fields, permissions, dashboard.\nCopilot/LLM: approved environment, allowed inputs, retention, review record.\nTellmeGen: no API Fase 1, manual status vocabulary, future reopening evidence.","fontSize":17,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Integration contracts to define\nweb/pago: events, fields, auth/signature, idempotency, sandbox, retries.\nHealthie: API/webhooks, report delivery, DPA/GDPR/residency, cost.\nOdoo: version, auth, object model, fields, permissions, dashboard.\nCopilot/LLM: approved environment, allowed inputs, retention, review record.\nTellmeGen: no API Fase 1, manual status vocabulary, future reopening evidence.","autoResize":false,"lineHeight":1.2},

    {"id":"text_state","type":"text","x":85,"y":958,"width":455,"height":320,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_state"],"frameId":null,"roundness":null,"seed":2401,"version":1,"versionNonce":2401,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"State lifecycle draft - workshop validation\nlead_received -> payment_pending -> payment_confirmed\nportal_invite_pending -> portal_invite_sent\nonboarding_started -> onboarding_completed\nconsent_pending -> consent_completed\nquestionnaire_pending -> questionnaire_completed\ndocuments_pending -> documents_received\ntellmegen_manual_pending -> tellmegen_result_available\nready_for_report -> report_in_preparation\nreport_in_human_review -> report_approved -> report_delivered\nfollow_up_active -> closed\nincident side state + manual recovery\nPrinciples: Odoo visible state; PostgreSQL technical snapshot; Healthie portal signals; TellmeGen manual milestones; every transition has source, actor/provider and timestamp.","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"State lifecycle draft - workshop validation\nlead_received -> payment_pending -> payment_confirmed\nportal_invite_pending -> portal_invite_sent\nonboarding_started -> onboarding_completed\nconsent_pending -> consent_completed\nquestionnaire_pending -> questionnaire_completed\ndocuments_pending -> documents_received\ntellmegen_manual_pending -> tellmegen_result_available\nready_for_report -> report_in_preparation\nreport_in_human_review -> report_approved -> report_delivered\nfollow_up_active -> closed\nincident side state + manual recovery\nPrinciples: Odoo visible state; PostgreSQL technical snapshot; Healthie portal signals; TellmeGen manual milestones; every transition has source, actor/provider and timestamp.","autoResize":false,"lineHeight":1.16},
    {"id":"text_data","type":"text","x":610,"y":958,"width":320,"height":320,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_data"],"frameId":null,"roundness":null,"seed":2402,"version":1,"versionNonce":2402,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"Sensitive data posture\nPersonal, health and genetic data are sensitive.\nNo raw genetic data in Odoo or PostgreSQL.\nPostgreSQL only stores IDs, event metadata, state snapshots, idempotency, retry/error records and sanitized audit markers.\nNo document bodies, report contents, sensitive prompts or request bodies in logs.\nUse secrets management, least privilege and documented retention.\nCopilot uses pseudonymized inputs, approved tools and mandatory human review.","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Sensitive data posture\nPersonal, health and genetic data are sensitive.\nNo raw genetic data in Odoo or PostgreSQL.\nPostgreSQL only stores IDs, event metadata, state snapshots, idempotency, retry/error records and sanitized audit markers.\nNo document bodies, report contents, sensitive prompts or request bodies in logs.\nUse secrets management, least privilege and documented retention.\nCopilot uses pseudonymized inputs, approved tools and mandatory human review.","autoResize":false,"lineHeight":1.18},
    {"id":"text_observability","type":"text","x":1000,"y":958,"width":320,"height":320,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_observability"],"frameId":null,"roundness":null,"seed":2403,"version":1,"versionNonce":2403,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"Observability / support / failure modes\nTrack inbound events by source/type/status, failed provider calls by provider/failure class, retry queue depth, dead-letter list, last Healthie/Odoo sync and report delivery markers.\nFailure responses: duplicate payment -> idempotency; malformed event -> sanitized reject; Odoo down -> retry/dead-letter/manual task; Healthie unavailable -> explicit fallback; missing webhook -> polling/manual check; unsafe Copilot input -> checklist gate; log payload leak -> redaction/error classes.\nSupport needs severity classes, channel and response expectations.","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Observability / support / failure modes\nTrack inbound events by source/type/status, failed provider calls by provider/failure class, retry queue depth, dead-letter list, last Healthie/Odoo sync and report delivery markers.\nFailure responses: duplicate payment -> idempotency; malformed event -> sanitized reject; Odoo down -> retry/dead-letter/manual task; Healthie unavailable -> explicit fallback; missing webhook -> polling/manual check; unsafe Copilot input -> checklist gate; log payload leak -> redaction/error classes.\nSupport needs severity classes, channel and response expectations.","autoResize":false,"lineHeight":1.14},
    {"id":"text_adr","type":"text","x":1390,"y":958,"width":285,"height":320,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_adr"],"frameId":null,"roundness":null,"seed":2404,"version":1,"versionNonce":2404,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"ADRs, gates and Unknowns\nFer reviews ADRs, risks, state model and slice decisions.\nAccepted direction: operational MVP, small software propio, NestJS, PostgreSQL tecnico, AWS Espana, Healthie hypothesis, Odoo backoffice, TellmeGen manual, Copilot draft support, data minimization, Raul solo.\nUnknown: Healthie API/DPA/cost, Odoo API/fields/hosting, web/pago schema/auth, report template, retention/LLM policy, volume/manual hours.\nWorkshop: final states, owners, forms, report readiness and dashboard.","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"ADRs, gates and Unknowns\nFer reviews ADRs, risks, state model and slice decisions.\nAccepted direction: operational MVP, small software propio, NestJS, PostgreSQL tecnico, AWS Espana, Healthie hypothesis, Odoo backoffice, TellmeGen manual, Copilot draft support, data minimization, Raul solo.\nUnknown: Healthie API/DPA/cost, Odoo API/fields/hosting, web/pago schema/auth, report template, retention/LLM policy, volume/manual hours.\nWorkshop: final states, owners, forms, report readiness and dashboard.","autoResize":false,"lineHeight":1.14},

    {"id":"text_flow1","type":"text","x":405,"y":295,"width":280,"height":48,"angle":0,"strokeColor":"#1D4ED8","backgroundColor":"#FFFFFF","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["flow_1"],"frameId":null,"roundness":null,"seed":2501,"version":1,"versionNonce":2501,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"1. lead/payment -> operational case","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"1. lead/payment -> operational case","autoResize":false,"lineHeight":1.2},
    {"id":"text_flow2","type":"text","x":1110,"y":402,"width":285,"height":48,"angle":0,"strokeColor":"#047857","backgroundColor":"#FFFFFF","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["flow_2"],"frameId":null,"roundness":null,"seed":2502,"version":1,"versionNonce":2502,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"2. portal onboarding -> Odoo state","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"2. portal onboarding -> Odoo state","autoResize":false,"lineHeight":1.2},
    {"id":"text_flow3","type":"text","x":690,"y":512,"width":300,"height":48,"angle":0,"strokeColor":"#C2410C","backgroundColor":"#FFFFFF","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["flow_3"],"frameId":null,"roundness":null,"seed":2503,"version":1,"versionNonce":2503,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"3. TellmeGen stays external/manual","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"3. TellmeGen stays external/manual","autoResize":false,"lineHeight":1.2},
    {"id":"text_flow4","type":"text","x":1045,"y":560,"width":330,"height":48,"angle":0,"strokeColor":"#7C2D12","backgroundColor":"#FFFFFF","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["flow_4"],"frameId":null,"roundness":null,"seed":2504,"version":1,"versionNonce":2504,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"4. report production -> review -> delivery","fontSize":18,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"4. report production -> review -> delivery","autoResize":false,"lineHeight":1.2},
    {"id":"text_legend","type":"text","x":1405,"y":20,"width":300,"height":84,"angle":0,"strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":["group_legend"],"frameId":null,"roundness":null,"seed":2505,"version":1,"versionNonce":2505,"isDeleted":false,"boundElements":[],"updated":1782260000000,"link":null,"locked":false,"text":"EPI10-owned     Manual\nExternal/SaaS   Unknown/gated\nSensitive data  Error/recovery","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"EPI10-owned     Manual\nExternal/SaaS   Unknown/gated\nSensitive data  Error/recovery","autoResize":false,"lineHeight":1.55}
